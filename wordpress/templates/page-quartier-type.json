                "typography_font_weight": "700",
                "typography_font_size": { "unit": "px", "size": 30 },
                "_padding": { "unit": "px", "top": "0", "right": "0", "bottom": "40", "left": "0", "isLinked": false }
              }
            },
            {
              "id": "nsad0053",
              "elType": "widget",
              "widgetType": "accordion",
              "settings": {
                "tabs": [
                  {
                    "_id": "faq01",
                    "tab_title": "Comment bénéficier des soins à domicile au [Quartier] ?",
                    "tab_content": "Pour bénéficier de nos services dans votre quartier, il vous suffit de nous contacter par téléphone au 02 40 35 43 43. Nous réalisons une évaluation gratuite de vos besoins à domicile et mettons en place un plan de soins personnalisé."
                  },
                  {
                    "_id": "faq02",
                    "tab_title": "Les soins sont-ils remboursés par l'Assurance Maladie ?",
                    "tab_content": "Oui, les soins infirmiers à domicile dispensés par notre SSIAD sont pris en charge à 100% par l'Assurance Maladie, sans avance de frais. Nous gérons toutes les démarches administratives pour vous."
                  },
                  {
                    "_id": "faq03",
                    "tab_title": "Quels sont vos délais d'intervention au [Quartier] ?",
                    "tab_content": "Nous intervenons généralement dans les 48 à 72 heures suivant votre demande. Pour les situations urgentes, nous mobilisons nos équipes dans les meilleurs délais. Contactez-nous directement pour évaluer votre situation."
                  },
                  {
                    "_id": "faq04",
                    "tab_title": "Travaillez-vous avec les médecins du [Quartier] ?",
                    "tab_content": "Oui, nous collaborons étroitement avec les médecins généralistes et spécialistes du quartier. Notre coordinatrice assure le lien entre notre équipe, votre médecin traitant et votre famille."
                  },
                  {
                    "_id": "faq05",
                    "tab_title": "Puis-je choisir mes horaires d'intervention ?",
                    "tab_content": "Oui, dans la mesure du possible, nous adaptons nos interventions à vos habitudes et à votre mode de vie. Nous respectons votre rythme et construisons un planning en accord avec vous."
                  }
                ],
                "active_item": 1,
                "title_html_tag": "div",
                "title_color": "#122432",
                "title_active_color": "#2E6A8A"
              }
            }
          ]
        }
      ]
